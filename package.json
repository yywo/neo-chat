{
  "name": "neo-chat",
  "description": "An omni AI chat application with a clean UI and excellent performance.",
  "private": true,
  "version": "2.2.3",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "worker:size": "node scripts/check-worker-size.mjs",
    "worker:dry-run": "wrangler deploy --dry-run --config wrangler.jsonc",
    "preview:worker": "opennextjs-cloudflare preview",
    "deploy:worker": "opennextjs-cloudflare deploy -- --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:imports": "node scripts/check-import-paths.mjs",
    "hygiene:artifacts": "node scripts/check-artifacts.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "byok:generate": "node scripts/generate-byok-key.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@xiangfa/mindmap": "^0.7.1",
    "fflate": "^0.8.3",
    "html-to-image": "^1.11.13",
    "katex": "^0.17.0",
    "localforage": "^1.10.0",
    "lucide-react": "1.23.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.1",
    "openai": "^6.45.0",
    "opfs-tools": "^0.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.108.0"
  }
}
